.tab-bar-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: -1px;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
  background: #ffffff;
  border-top: 1rpx solid #e8e8e8;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 120;
}

.tab-bar-main {
  height: 104rpx;
  display: flex;
  align-items: stretch;
}

.tab-bar-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-bar-item-active {
  background: #f5fbf8;
}

.tab-bar-icon-wrap {
  min-width: 60rpx;
  height: 60rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-bar-icon-wrap-active {
  background: transparent;
}

.tab-bar-icon {
  color: #6b6b6b;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.1;
}

.tab-bar-item-active .tab-bar-icon {
  color: #0d6b45;
}
