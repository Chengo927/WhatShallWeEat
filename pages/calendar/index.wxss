.calendar-page {
  min-height: 100vh;
  height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #f4f4f4;
  overflow: hidden;
}

.calendar-header {
  flex-shrink: 0;
  height: 96rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  display: flex;
  align-items: center;
}

.calendar-title {
  color: #1e1e1e;
  font-size: 40rpx;
  font-weight: 700;
}

.calendar-scroll {
  flex: 1;
  min-height: 0;
  height: 0;
}

.calendar-content {
  padding: 10rpx 24rpx 0;
  box-sizing: border-box;
}

.calendar-summary {
  margin-top: 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.calendar-summary-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.calendar-head-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.calendar-summary-title {
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 600;
}

.calendar-edit-btn {
  flex-shrink: 0;
  min-width: 84rpx;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid #e2e2e2;
  color: #1f1f1f;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 46rpx;
  text-align: center;
}

.calendar-edit-btn-active {
  color: #00643e;
  border-color: #d8e6df;
  background: #f3fbf7;
}

.calendar-add-panel {
  margin-top: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e9f0ec;
  background: #fafdfb;
  padding: 10rpx 14rpx;
  box-sizing: border-box;
}

.calendar-add-list {
  width: 100%;
}

.calendar-add-item {
  min-height: 62rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #edf3ef;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.calendar-add-item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.calendar-add-item-name {
  color: #2a2a2a;
  font-size: 26rpx;
}

.calendar-add-item-emoji {
  color: #666666;
  font-size: 22rpx;
}

.calendar-add-item-btn {
  flex-shrink: 0;
  min-width: 72rpx;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid #d8e6df;
  color: #00643e;
  background: #f3fbf7;
  font-size: 22rpx;
  line-height: 40rpx;
  text-align: center;
}

.calendar-add-item-btn-remove {
  color: #cf4343;
  border-color: #f3c0c0;
  background: #fff7f7;
}

.calendar-add-empty {
  display: block;
  color: #8a8a8a;
  font-size: 24rpx;
  text-align: center;
  padding: 20rpx 0;
}

.calendar-dish-list {
  margin-top: 14rpx;
}

.calendar-dish-item {
  height: 64rpx;
  padding: 0 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.calendar-dish-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.calendar-dish-name {
  flex: 1;
  min-width: 0;
  color: #1f1f1f;
  font-size: 28rpx;
}

.calendar-dish-emoji {
  color: #666666;
  font-size: 24rpx;
}

.calendar-empty {
  display: block;
  margin-top: 16rpx;
  color: #868686;
  font-size: 26rpx;
}

.calendar-bottom-spacer {
  height: calc(124rpx + env(safe-area-inset-bottom));
}
