.calendar-page {
  min-height: 100vh;
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #f4f4f4;
}

.calendar-header {
  flex-shrink: 0;
  height: 96rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  display: flex;
  align-items: center;
}

.calendar-title {
  color: #1e1e1e;
  font-size: 40rpx;
  font-weight: 700;
}

.calendar-scroll {
  flex: 1;
  min-height: 0;
}

.calendar-content {
  padding: 10rpx 24rpx 0;
  box-sizing: border-box;
}

.calendar-summary {
  margin-top: 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.calendar-summary-title {
  display: block;
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 600;
}

.calendar-summary-meta {
  display: block;
  margin-top: 8rpx;
  color: #5f5f5f;
  font-size: 24rpx;
}

.calendar-dish-list {
  margin-top: 14rpx;
}

.calendar-dish-item {
  height: 64rpx;
  padding: 0 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.calendar-dish-name {
  flex: 1;
  min-width: 0;
  color: #1f1f1f;
  font-size: 28rpx;
}

.calendar-dish-emoji {
  color: #666666;
  font-size: 24rpx;
}

.calendar-empty {
  display: block;
  margin-top: 16rpx;
  color: #868686;
  font-size: 26rpx;
}

.calendar-bottom-spacer {
  height: calc(124rpx + env(safe-area-inset-bottom));
}
