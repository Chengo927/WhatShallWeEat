<view class="calendar-page">
  <view class="calendar-header" style="padding-top: {{statusBarHeight}}px;">
    <text class="calendar-title">日历</text>
  </view>

  <scroll-view class="calendar-scroll" scroll-y show-scrollbar="{{false}}">
    <view class="calendar-content">
      <meal-calendar
        value="{{selectedDate}}"
        marks="{{calendarMarks}}"
        bindchange="onCalendarChange"
      ></meal-calendar>

      <view class="calendar-summary">
        <view class="calendar-summary-head">
          <text class="calendar-summary-title">当前菜品 {{selectedMenu.length}} 道</text>
          <view class="calendar-head-actions">
            <view class="calendar-add-btn" bindtap="onToggleAddPanel">
              {{showAddPanel ? '收起' : '添加'}}
            </view>
            <view
              class="calendar-edit-btn {{selectedMenu.length ? '' : 'calendar-edit-btn-disabled'}}"
              bindtap="onToggleEdit"
            >
              {{isEditing ? '完成' : '编辑'}}
            </view>
          </view>
        </view>
        <view wx:if="{{showAddPanel}}" class="calendar-add-panel">
          <view wx:if="{{allDishOptions.length}}" class="calendar-add-list">
            <block wx:for="{{allDishOptions}}" wx:key="id">
              <view class="calendar-add-item">
                <view class="calendar-add-item-main">
                  <text class="calendar-add-item-name">{{item.name}}</text>
                  <text wx:if="{{item.emoji}}" class="calendar-add-item-emoji">{{item.emoji}}</text>
                </view>
                <view wx:if="{{item.added}}" class="calendar-add-item-btn calendar-add-item-btn-disabled">
                  已选
                </view>
                <view wx:else class="calendar-add-item-btn" data-dish-id="{{item.id}}" bindtap="onAddDish">
                  添加
                </view>
              </view>
            </block>
          </view>
          <text wx:else class="calendar-add-empty">暂无可添加菜品</text>
        </view>
        <view wx:if="{{selectedMenu.length}}" class="calendar-dish-list">
          <block wx:for="{{selectedMenu}}" wx:key="id">
            <view class="calendar-dish-item">
              <text class="calendar-dish-name">{{item.name}}</text>
              <view class="calendar-dish-actions">
                <text wx:if="{{item.emoji}}" class="calendar-dish-emoji">{{item.emoji}}</text>
                <view
                  wx:if="{{isEditing}}"
                  class="calendar-remove-btn"
                  data-dish-id="{{item.id}}"
                  bindtap="onRemoveDish"
                >
                  移除
                </view>
              </view>
            </view>
          </block>
        </view>
        <text wx:else class="calendar-empty">这一天还没有已选菜品</text>
      </view>
    </view>

    <view class="calendar-bottom-spacer"></view>
  </scroll-view>
</view>
