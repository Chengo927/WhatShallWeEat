<view class="order-page">
  <view class="custom-header" style="height: {{navBarHeight}}px; padding-top: {{menuButtonTop}}px;">
    <view class="custom-header-row" style="height: {{menuButtonHeight}}px;">
      <view class="custom-header-title-wrap">
        <text class="custom-header-title">今天吃什么呢？</text>
      </view>
      <view class="custom-header-placeholder" style="width: {{capsulePlaceholderWidth}}px;"></view>
    </view>
  </view>

  <view class="page-head">
    <view class="page-head-meta">
      <text class="selected-date">已选日期：{{dateLabel}}</text>
      <view
        class="calendar-entry"
        bindtap="onOpenCalendar"
        hover-class="calendar-entry--active"
        hover-stay-time="80"
        aria-role="button"
        aria-label="打开日历"
      >
        <view class="calendar-icon">
          <view class="calendar-icon__top"></view>
          <view class="calendar-icon__grid">
            <view class="calendar-icon__dot"></view>
            <view class="calendar-icon__dot"></view>
            <view class="calendar-icon__dot"></view>
            <view class="calendar-icon__dot"></view>
            <view class="calendar-icon__dot"></view>
            <view class="calendar-icon__dot"></view>
          </view>
        </view>
      </view>
    </view>
    <view class="search-wrap">
      <search-bar value="{{searchKeyword}}" placeholder="Search" bindchange="onSearchChange"></search-bar>
    </view>
  </view>

  <view wx:if="{{pageReady}}" class="content-wrap">
    <view class="category-pane">
      <view class="category-chips-wrap">
        <category-chips
          categories="{{categories}}"
          selected="{{selectedCategory}}"
          vertical="{{true}}"
          bindchange="onCategoryChange"
        ></category-chips>
      </view>
    </view>

    <scroll-view
      class="dish-scroll"
      scroll-y
      show-scrollbar="{{false}}"
      bindscrolltolower="onScrollToLower"
    >
      <view class="dish-list">
        <block wx:for="{{visibleDishes}}" wx:key="id">
          <dish-card
            dish="{{item}}"
            disabled="{{item.added}}"
            pending="{{item.pending}}"
            action-text="大吃特吃"
            bindaction="onAddDish"
            bindpendingaction="onTogglePending"
            bindimageerror="onDishImageError"
          ></dish-card>
        </block>
        <view wx:if="{{!visibleDishes.length}}" class="empty-state">暂无匹配菜品</view>
        <view class="bottom-reached-hint">{{bottomHint}}</view>
        <view class="list-bottom-spacer"></view>
      </view>
    </scroll-view>
  </view>

  <view wx:else class="content-wrap content-loading"></view>

  <view class="bottom-bar">
    <text class="bottom-count">今日已选 {{selectedDishIds.length}} 道</text>
    <view class="bottom-button" bindtap="onOpenSummary">查看已选</view>
  </view>

  <view wx:if="{{showSummaryPopup}}" class="popup-mask" bindtap="onCloseSummary"></view>
  <view wx:if="{{showSummaryPopup}}" class="popup-panel">
    <view class="popup-header">
      <view class="popup-header-main">
        <text class="popup-title">今日菜单</text>
        <text class="popup-close" bindtap="onCloseSummary">关闭</text>
      </view>
      <view
        class="popup-lottery-entry {{thinkPoolCount ? '' : 'popup-lottery-entry-disabled'}}"
        bindtap="onOpenLottery"
      >
        <text class="popup-lottery-title">抽奖</text>
        <text class="popup-lottery-meta">候选池 {{thinkPoolCount}} 道</text>
      </view>
    </view>
    <scroll-view class="popup-scroll" scroll-y>
      <view wx:if="{{!selectedDishes.length}}" class="popup-empty">今天还没有加入菜品</view>
      <block wx:for="{{selectedDishes}}" wx:key="id">
        <view class="popup-item">
          <view class="popup-item-main">
            <image
              class="popup-item-thumb"
              src="{{item.img || placeholderImg}}"
              mode="aspectFill"
              data-dish-id="{{item.id}}"
              binderror="onSummaryImageError"
            />
            <text class="popup-item-name">{{item.name}}</text>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>

  <view wx:if="{{showLotteryPopup}}" class="popup-mask lottery-mask" bindtap="onCloseLottery"></view>
  <view wx:if="{{showLotteryPopup}}" class="lottery-panel">
    <view class="lottery-header">
      <text class="lottery-title">抽奖系统</text>
      <text class="lottery-close" bindtap="onCloseLottery">关闭</text>
    </view>
    <view class="lottery-body">
      <text class="lottery-desc">容我想想候选池共 {{lotteryMaxCount}} 道菜</text>
      <view class="lottery-count-row">
        <text class="lottery-count-label">抽取数量</text>
        <view class="lottery-stepper">
          <view class="lottery-stepper-btn" bindtap="onDecreaseLotteryCount">-</view>
          <input
            class="lottery-count-input"
            type="number"
            value="{{lotteryCount}}"
            bindinput="onLotteryCountInput"
          />
          <view class="lottery-stepper-btn" bindtap="onIncreaseLotteryCount">+</view>
        </view>
      </view>
      <text class="lottery-tip">开始/再抽只预览，点击“确定”才写入今日菜单</text>
      <view class="lottery-action-row">
        <view wx:if="{{!hasDrawn}}" class="lottery-action-btn lottery-action-btn-ghost" bindtap="onStartLottery">
          开始抽奖
        </view>
        <view wx:else class="lottery-action-btn lottery-action-btn-ghost" bindtap="onRedrawLottery">
          再抽一次
        </view>
      </view>
      <view
        class="lottery-confirm-btn {{hasDrawn && pendingResult.length ? '' : 'lottery-confirm-btn-disabled'}}"
        bindtap="onConfirmLottery"
      >
        确定
      </view>
    </view>
    <scroll-view class="lottery-result-scroll" scroll-y>
      <text class="lottery-result-title">抽奖结果</text>
      <view wx:if="{{!pendingResult.length}}" class="lottery-empty">点击开始抽奖后显示结果</view>
      <block wx:for="{{pendingResult}}" wx:key="id">
        <view class="lottery-item">
          <image
            class="lottery-item-thumb"
            src="{{item.img || placeholderImg}}"
            mode="aspectFill"
            data-dish-id="{{item.id}}"
            binderror="onLotteryImageError"
          />
          <text class="lottery-item-name">{{item.name}}</text>
        </view>
      </block>
    </scroll-view>
  </view>

  <calendar-popup
    visible="{{showCalendarPopup}}"
    value="{{today}}"
    marks="{{calendarMarks}}"
    bindclose="onCloseCalendar"
    bindconfirm="onCalendarConfirm"
  ></calendar-popup>
</view>
