.order-page {
  min-height: 100vh;
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  background: #f4f4f4;
  overflow: hidden;
}

.custom-header {
  flex-shrink: 0;
  width: 100%;
  padding: 0 22rpx;
  box-sizing: border-box;
}

.custom-header-row {
  width: 100%;
  display: flex;
  align-items: center;
}

.custom-header-title-wrap {
  flex: 1;
  min-width: 0;
  max-width: 100%;
  height: 100%;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #f9d95a;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.custom-header-title {
  color: #00643e;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.custom-header-placeholder {
  flex-shrink: 0;
  height: 100%;
}

.page-head {
  flex-shrink: 0;
  padding: 8rpx 22rpx 16rpx;
  box-sizing: border-box;
}

.page-head-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.calendar-entry {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.calendar-entry--active {
  opacity: 0.75;
}

.calendar-icon {
  width: 40rpx;
  height: 44rpx;
  border: 3rpx solid #00643e;
  border-radius: 8rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.calendar-icon__top {
  height: 10rpx;
  background: #00643e;
}

.calendar-icon__grid {
  padding: 6rpx 4rpx 0;
  display: flex;
  flex-wrap: wrap;
  gap: 3rpx;
  box-sizing: border-box;
}

.calendar-icon__dot {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: rgba(0, 100, 62, 0.55);
}

.selected-date {
  flex: 1;
  min-width: 0;
  color: #6f6f6f;
  font-size: 24rpx;
}

.search-wrap {
  margin-top: 12rpx;
}

.content-wrap {
  flex: 1;
  min-height: 0;
  display: flex;
  gap: 16rpx;
  padding: 0 22rpx calc(224rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow: hidden;
}

.content-loading {
  background: transparent;
}

.category-pane {
  flex: 0 0 176rpx;
  min-height: 0;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.category-chips-wrap {
  height: 100%;
}

.dish-scroll {
  flex: 1;
  min-width: 0;
  min-height: 0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.dish-list {
  padding-top: 10rpx;
}

.empty-state {
  text-align: center;
  color: #8f8f8f;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.bottom-reached-hint {
  text-align: center;
  color: #a1a1a1;
  font-size: 24rpx;
  padding: 16rpx 0 20rpx;
}

.list-bottom-spacer {
  height: 36rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(104rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 24rpx;
  background: #ffffff;
  box-shadow: 0 -6rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 30;
}

.bottom-count {
  font-size: 28rpx;
  color: #2d2d2d;
}

.bottom-button {
  height: 68rpx;
  line-height: 68rpx;
  min-width: 188rpx;
  padding: 0 26rpx;
  text-align: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  background: #00643e;
  border-radius: 34rpx;
  box-sizing: border-box;
}

.popup-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 40;
}

.popup-panel {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(224rpx + env(safe-area-inset-bottom));
  height: 640rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-sizing: border-box;
  z-index: 50;
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #efefef;
}

.popup-header-main {
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.popup-title {
  font-size: 32rpx;
  color: #1f1f1f;
  font-weight: 600;
}

.popup-close {
  font-size: 28rpx;
  color: #00643e;
}

.popup-lottery-entry {
  height: 94rpx;
  border-radius: 18rpx;
  padding: 0 24rpx;
  background: #db4b4b;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.popup-lottery-entry-disabled {
  background: #e9d7d7;
}

.popup-lottery-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.popup-lottery-meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.popup-lottery-entry-disabled .popup-lottery-title,
.popup-lottery-entry-disabled .popup-lottery-meta {
  color: #927e7e;
}

.popup-scroll {
  flex: 1;
  min-height: 0;
  padding-top: 14rpx;
}

.popup-empty {
  text-align: center;
  color: #8f8f8f;
  font-size: 28rpx;
  padding: 100rpx 0;
}

.popup-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f1f1f1;
}

.popup-item-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.popup-item-thumb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #f3f3f3;
  flex-shrink: 0;
  display: block;
}

.popup-item-name {
  display: block;
  font-size: 30rpx;
  color: #151515;
  font-weight: 600;
}

.lottery-mask {
  z-index: 60;
}

.lottery-panel {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(224rpx + env(safe-area-inset-bottom));
  height: 720rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-sizing: border-box;
  z-index: 70;
  display: flex;
  flex-direction: column;
}

.lottery-header {
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lottery-title {
  font-size: 32rpx;
  color: #1f1f1f;
  font-weight: 600;
}

.lottery-close {
  font-size: 28rpx;
  color: #00643e;
}

.lottery-body {
  border-top: 1rpx solid #efefef;
  border-bottom: 1rpx solid #efefef;
  padding: 20rpx 0;
}

.lottery-desc {
  display: block;
  color: #5a5a5a;
  font-size: 25rpx;
}

.lottery-count-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lottery-count-label {
  color: #1f1f1f;
  font-size: 28rpx;
  font-weight: 600;
}

.lottery-stepper {
  display: flex;
  align-items: center;
  border: 1rpx solid #d8d8d8;
  border-radius: 28rpx;
  overflow: hidden;
}

.lottery-stepper-btn {
  width: 58rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 34rpx;
  color: #0f6a47;
  background: #f6f6f6;
}

.lottery-count-input {
  width: 90rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  color: #1f1f1f;
  font-size: 28rpx;
}

.lottery-tip {
  display: block;
  margin-top: 16rpx;
  color: #6c6c6c;
  font-size: 24rpx;
}

.lottery-action-row {
  margin-top: 16rpx;
  display: flex;
  gap: 14rpx;
}

.lottery-action-btn {
  flex: 1;
  height: 66rpx;
  line-height: 66rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 34rpx;
}

.lottery-action-btn-ghost {
  color: #d34b4b;
  border: 1rpx solid #d34b4b;
  background: #fff5f5;
}

.lottery-action-btn-disabled {
  color: #ae9999;
  border-color: #e7d7d7;
  background: #f6eeee;
}

.lottery-confirm-btn {
  margin-top: 14rpx;
  height: 66rpx;
  line-height: 66rpx;
  text-align: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 34rpx;
  background: #d34b4b;
}

.lottery-confirm-btn-disabled {
  background: #e1c8c8;
  color: #f7f1f1;
}

.lottery-result-scroll {
  flex: 1;
  min-height: 0;
  padding-top: 16rpx;
}

.lottery-result-title {
  display: block;
  color: #1f1f1f;
  font-size: 28rpx;
  font-weight: 600;
}

.lottery-empty {
  text-align: center;
  color: #8f8f8f;
  font-size: 26rpx;
  padding: 70rpx 0;
}

.lottery-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f1f1f1;
}

.lottery-item-thumb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #f3f3f3;
  flex-shrink: 0;
  display: block;
}

.lottery-item-name {
  font-size: 30rpx;
  color: #151515;
  font-weight: 600;
}
