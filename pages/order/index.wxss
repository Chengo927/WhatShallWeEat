page {
  height: 100vh;
}

.order-page {
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  background: #f4f4f4;
  overflow: hidden;
}

.status-placeholder {
  flex-shrink: 0;
  width: 100%;
}

.page-head {
  flex-shrink: 0;
  padding: 0 22rpx 22rpx;
  box-sizing: border-box;
}

.page-head-main {
  margin-top: 24rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.page-title {
  flex: 1;
  min-width: 0;
  color: #00643e;
  font-size: 56rpx;
  font-weight: 700;
}

.calendar-entry {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.calendar-entry--active {
  opacity: 0.75;
}

.calendar-icon {
  width: 48rpx;
  height: 54rpx;
  border: 3rpx solid #00643e;
  border-radius: 10rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.calendar-icon__top {
  height: 12rpx;
  background: #00643e;
}

.calendar-icon__grid {
  padding: 8rpx 6rpx 0;
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
  box-sizing: border-box;
}

.calendar-icon__dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0, 100, 62, 0.55);
}

.selected-date {
  display: block;
  margin-top: 10rpx;
  color: #6f6f6f;
  font-size: 24rpx;
}

.search-wrap {
  margin-top: 20rpx;
}

.content-wrap {
  flex: 1;
  min-height: 0;
  display: flex;
  gap: 16rpx;
  padding: 0 22rpx calc(116rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow: hidden;
}

.content-loading {
  background: transparent;
}

.category-pane {
  flex: 0 0 176rpx;
  min-height: 0;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.category-pane category-chips {
  display: block;
  height: 100%;
}

.dish-scroll {
  flex: 1;
  min-width: 0;
  min-height: 0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.dish-list {
  padding-top: 10rpx;
}

.empty-state {
  text-align: center;
  color: #8f8f8f;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.bottom-reached-hint {
  text-align: center;
  color: #a1a1a1;
  font-size: 24rpx;
  padding: 16rpx 0 20rpx;
}

.list-bottom-spacer {
  height: 36rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -6rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 30;
}

.bottom-count {
  font-size: 28rpx;
  color: #2d2d2d;
}

.bottom-button {
  height: 68rpx;
  line-height: 68rpx;
  min-width: 188rpx;
  padding: 0 26rpx;
  text-align: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  background: #00643e;
  border-radius: 34rpx;
  box-sizing: border-box;
}

.popup-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 40;
}

.popup-panel {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(116rpx + env(safe-area-inset-bottom));
  height: 560rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-sizing: border-box;
  z-index: 50;
  display: flex;
  flex-direction: column;
}

.popup-header {
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #efefef;
}

.popup-title {
  font-size: 32rpx;
  color: #1f1f1f;
  font-weight: 600;
}

.popup-close {
  font-size: 28rpx;
  color: #00643e;
}

.popup-scroll {
  flex: 1;
  min-height: 0;
  padding-top: 14rpx;
}

.popup-empty {
  text-align: center;
  color: #8f8f8f;
  font-size: 28rpx;
  padding: 100rpx 0;
}

.popup-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f1f1f1;
}

.popup-item-name {
  display: block;
  font-size: 30rpx;
  color: #151515;
  font-weight: 600;
}
