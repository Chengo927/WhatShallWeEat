.empty-page {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  background: #f7f7f3;
}

.empty-card {
  margin-top: 120rpx;
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.06);
}

.empty-title {
  display: block;
  color: #111111;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
}

.empty-desc {
  display: block;
  margin-top: 18rpx;
  color: #666666;
  font-size: 26rpx;
  line-height: 1.6;
}
