<scroll-view
  class="chips-scroll {{vertical ? 'chips-scroll-vertical' : ''}}"
  scroll-x="{{!vertical}}"
  scroll-y="{{vertical}}"
  show-scrollbar="{{false}}"
>
  <view class="chips-row {{vertical ? 'chips-col' : ''}}">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="chip {{vertical ? 'chip-vertical' : ''}} {{selected === item.id ? 'chip-active' : ''}}"
      data-value="{{item.id}}"
      bindtap="onTapChip"
    >
      <text class="chip-text {{vertical ? 'chip-text-vertical' : ''}}">{{item.label}}</text>
    </view>
  </view>
</scroll-view>
