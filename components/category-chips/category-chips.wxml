<scroll-view class="chips-scroll" scroll-x show-scrollbar="{{false}}">
  <view class="chips-row">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="chip {{selected === item.id ? 'chip-active' : ''}}"
      data-value="{{item.id}}"
      bindtap="onTapChip"
    >
      <text class="chip-text">{{item.label}}</text>
    </view>
  </view>
</scroll-view>
