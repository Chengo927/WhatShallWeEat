.chips-scroll {
  width: 100%;
  white-space: nowrap;
}

.chips-vertical-wrap {
  height: 100%;
  overflow: hidden;
}

.chips-row {
  display: flex;
  padding: 10rpx 0 16rpx;
}

.chips-col {
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx 10rpx;
}

.chip {
  width: 210rpx;
  height: 170rpx;
  border-radius: 24rpx;
  background: #1aa570;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 28rpx;
  box-sizing: border-box;
  margin-right: 18rpx;
}

.chip-vertical {
  width: 100%;
  min-height: 84rpx;
  height: auto;
  margin-right: 0;
  border-radius: 14rpx;
  background: #f0f3f1;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
}

.chip-active {
  background: #00643e;
}

.chip-vertical.chip-active {
  background: #e8f5ef;
}

.chip-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.chip-text-vertical {
  color: #2b2b2b;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
}

.chip-vertical.chip-active .chip-text-vertical {
  color: #00643e;
  font-weight: 700;
}
