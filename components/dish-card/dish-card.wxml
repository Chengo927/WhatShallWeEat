<view class="dish-card">
  <view class="thumb-wrap">
    <image
      wx:if="{{dish.image}}"
      class="thumb-image"
      src="{{dish.image}}"
      mode="aspectFit"
    />
    <text wx:else class="thumb-emoji">{{dish.emoji || '🍔'}}</text>
  </view>

  <view class="dish-content">
    <text class="dish-title">{{dish.name}}</text>
  </view>

  <view class="action-wrap">
    <view
      class="action-btn {{actionVariant === 'danger' ? 'action-btn-danger' : ''}} {{disabled ? 'action-btn-disabled' : ''}}"
      bindtap="onTapAction"
    >
      {{disabled ? disabledText : actionText}}
    </view>
    <view
      class="pending-btn {{pending ? 'pending-btn-active' : ''}}"
      bindtap="onTapPending"
    >
      {{pending ? pendingActiveText : pendingText}}
    </view>
  </view>
</view>
