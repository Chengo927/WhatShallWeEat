.dish-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 8rpx;
}

.thumb-wrap {
  width: 136rpx;
  height: 136rpx;
  border-radius: 20rpx;
  background: #1aa570;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.thumb-image {
  width: 108rpx;
  height: 108rpx;
}

.thumb-emoji {
  font-size: 72rpx;
  line-height: 1;
}

.dish-content {
  flex: 1;
  min-width: 0;
}

.dish-title {
  color: #111111;
  font-size: 42rpx;
  line-height: 1.2;
}

.dish-desc {
  margin-top: 10rpx;
  color: #8d8d8d;
  font-size: 22rpx;
  line-height: 1.4;
}

.action-btn {
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  color: #111111;
  font-size: 56rpx;
  font-weight: 400;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.action-btn-danger {
  color: #c23a3a;
  font-size: 42rpx;
}

.action-btn-disabled {
  color: #9f9f9f;
  font-size: 34rpx;
}
