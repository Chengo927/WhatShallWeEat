.dish-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 4rpx;
  border-bottom: 1rpx solid #f1f1f1;
}

.thumb-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: #f3f3f3;
  overflow: hidden;
  flex-shrink: 0;
}

.thumb-image {
  width: 100%;
  height: 100%;
  display: block;
}

.dish-content {
  flex: 1;
  min-width: 0;
}

.dish-title {
  color: #111111;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 600;
}

.dish-desc {
  margin-top: 10rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.5;
}


.action-wrap {
  flex-shrink: 0;
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.action-btn {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 20rpx;
  text-align: center;
  color: #00643e;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #00643e;
  border-radius: 26rpx;
  box-sizing: border-box;
}

.action-btn-danger {
  color: #c23a3a;
  border-color: #c23a3a;
}

.action-btn-disabled {
  color: #9f9f9f;
  border-color: transparent;
  background: #f3f3f3;
}

.pending-btn {
  min-width: 112rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 18rpx;
  text-align: center;
  color: #3d6b6b;
  font-size: 22rpx;
  border: 1rpx solid #8fb7b7;
  border-radius: 24rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.pending-btn-active {
  color: #0e6f63;
  border-color: #0e6f63;
  background: #e8f7f4;
}
