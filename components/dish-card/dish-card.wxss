.dish-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 4rpx;
  border-bottom: 1rpx solid #f1f1f1;
}

.thumb-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: #1aa570;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.thumb-image {
  width: 88rpx;
  height: 88rpx;
}

.thumb-emoji {
  font-size: 56rpx;
  line-height: 1;
}

.dish-content {
  flex: 1;
  min-width: 0;
}

.dish-title {
  color: #111111;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 600;
}

.dish-desc {
  margin-top: 8rpx;
  color: #8d8d8d;
  font-size: 22rpx;
  line-height: 1.4;
}

.action-btn {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin-top: 12rpx;
  padding: 0 20rpx;
  text-align: center;
  color: #00643e;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #00643e;
  border-radius: 26rpx;
  box-sizing: border-box;
  align-self: center;
}

.action-btn-danger {
  color: #c23a3a;
  border-color: #c23a3a;
}

.action-btn-disabled {
  color: #9f9f9f;
  border-color: transparent;
  background: #f3f3f3;
}
